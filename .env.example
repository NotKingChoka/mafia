# Frontend URL allowed to connect to the backend.
CORS_ORIGIN=http://localhost:5173

# Backend port.
PORT=4000

# Frontend uses this to connect to Socket.IO.
VITE_SOCKET_URL=http://localhost:4000

# Optional WebRTC/STUN preparation.
WEBRTC_STUN_URL=stun:stun.l.google.com:19302

# Optional AI for talking bots. Leave disabled for local fallback phrases.
BOT_AI_ENABLED=false
BOT_AI_API_URL=https://api.openai.com/v1/chat/completions
BOT_AI_MODEL=gpt-4o-mini
BOT_AI_API_KEY=
BOT_AI_TIMEOUT_MS=4500
